<!--pages/cart/cart.wxml - 购物车页-->
<view class="container">
  <!-- 空购物车 -->
  <view class="empty-cart" wx:if="{{cartList.length === 0}}">
    <image class="empty-image" src="/images/icon-empty-cart.png" mode="aspectFit" />
    <text class="empty-text">购物车是空的</text>
    <text class="empty-hint">快去挑选喜欢的鲜花吧~</text>
    <view class="go-shopping" bindtap="goShopping">去逛逛</view>
  </view>

  <!-- 购物车列表 -->
  <view class="cart-list" wx:else>
    <!-- 全选 -->
    <view class="cart-header">
      <view class="checkbox {{allSelected ? 'checked' : ''}}" bindtap="toggleSelectAll">
        <text class="check-icon">{{allSelected ? '✓' : ''}}</text>
      </view>
      <text class="select-all">全选</text>
      <text class="edit-btn" bindtap="toggleEdit">{{isEditing ? '完成' : '编辑'}}</text>
    </view>

    <!-- 商品列表 -->
    <view class="cart-item" wx:for="{{cartList}}" wx:key="id">
      <view class="checkbox {{item.selected ? 'checked' : ''}}" bindtap="toggleSelect" data-index="{{index}}">
        <text class="check-icon">{{item.selected ? '✓' : ''}}</text>
      </view>
      <image class="goods-image" src="{{item.image}}" mode="aspectFill" bindtap="goGoodsDetail" data-id="{{item.goodsId}}"></image>
      <view class="goods-info">
        <text class="goods-name">{{item.name}}</text>
        <text class="goods-spec">{{item.spec}}</text>
        <view class="goods-bottom">
          <view class="goods-price">
            <text class="price-symbol">¥</text>
            <text class="price-value">{{item.price}}</text>
          </view>
          <view class="quantity-control">
            <view class="qty-btn minus {{item.quantity <= 1 ? 'disabled' : ''}}" bindtap="onQuantityMinus" data-index="{{index}}">-</view>
            <text class="qty-value">{{item.quantity}}</text>
            <view class="qty-btn plus" bindtap="onQuantityPlus" data-index="{{index}}">+</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部结算栏 -->
  <view class="bottom-bar" wx:if="{{cartList.length > 0}}">
    <view class="total-section">
      <text class="total-label">合计：</text>
      <text class="total-price">¥{{totalPrice}}</text>
    </view>
    <view class="btn-checkout" bindtap="onCheckout" wx:if="{{!isEditing}}">
      结算({{selectedCount}})
    </view>
    <view class="btn-delete" bindtap="onDelete" wx:else>
      删除
    </view>
  </view>
</view>
