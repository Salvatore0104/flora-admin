/* pages/category/category.wxss - 分类页样式 */

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  background-color: #FFFFFF;
  padding: 20rpx 30rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 44rpx;
  padding: 16rpx 30rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 分类内容区 */
.category-content {
  flex: 1;
  display: flex;
  overflow: hidden;
}

/* 左侧分类栏 */
.left-category {
  width: 200rpx;
  height: 100%;
  background-color: #F5F5F5;
  flex-shrink: 0;
}

.category-item {
  padding: 36rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.category-item.active {
  background-color: #fff;
  color: #333333;
  font-weight: 600;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 40rpx;
  background-color: #333333;
  border-radius: 0 4rpx 4rpx 0;
}

/* 右侧商品区 */
.right-goods {
  flex: 1;
  height: 100%;
  background-color: #fff;
  padding: 20rpx;
}

/* 分类横幅 */
.category-banner {
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.banner-image {
  width: 100%;
  height: 200rpx;
  background-color: #f5f5f5;
}

/* 子分类 */
.sub-category {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.sub-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.sub-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
}

.sub-name {
  font-size: 24rpx;
  color: #666;
}

/* 排序栏 */
.sort-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.sort-item {
  font-size: 26rpx;
  color: #999;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  transition: all 0.3s;
}

.sort-item.active {
  color: #333333;
  background-color: #F5F5F5;
  font-weight: 500;
}

/* 商品列表 */
.goods-list {
  padding-bottom: 20rpx;
}

.goods-item {
  display: flex;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.goods-item:active {
  transform: scale(0.98);
}

.goods-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.goods-desc {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 8rpx;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.goods-price {
  color: #E91E63;
  font-weight: 600;
}

.price-symbol {
  font-size: 24rpx;
}

.price-value {
  font-size: 36rpx;
}

.goods-sales {
  font-size: 22rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state .text {
  color: #999;
  font-size: 28rpx;
}
