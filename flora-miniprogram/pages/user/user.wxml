<!--pages/user/user.wxml - 个人中心页-->
<view class="container">
  <!-- 用户信息区 -->
  <view class="user-header">
    <view class="user-info" wx:if="{{isLogin}}">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/avatar-default.png'}}" mode="aspectFill"></image>
      <view class="user-detail">
        <text class="nickname">{{userInfo.nickName || '花友'}}</text>
        <view class="member-badge">
          <text class="badge-text">会员</text>
        </view>
      </view>
      <text class="settings" bindtap="goSettings">⚙</text>
    </view>
    <view class="login-prompt" wx:else bindtap="onLogin">
      <image class="avatar" src="/images/icon-home.png" mode="aspectFill"></image>
      <text class="login-text">点击登录</text>
    </view>
  </view>

  <!-- 订单状态 -->
  <view class="order-section card">
    <view class="section-header">
      <text class="section-title">我的订单</text>
      <text class="view-all" bindtap="goOrderList">全部订单 ></text>
    </view>
    <view class="order-status">
      <view class="status-item" bindtap="goOrderList" data-status="pending">
        <view class="status-icon">💳</view>
        <text class="status-text">待付款</text>
        <view class="badge" wx:if="{{orderCounts.pending > 0}}">{{orderCounts.pending}}</view>
      </view>
      <view class="status-item" bindtap="goOrderList" data-status="paid">
        <view class="status-icon">📦</view>
        <text class="status-text">待发货</text>
        <view class="badge" wx:if="{{orderCounts.paid > 0}}">{{orderCounts.paid}}</view>
      </view>
      <view class="status-item" bindtap="goOrderList" data-status="shipped">
        <view class="status-icon">🚚</view>
        <text class="status-text">待收货</text>
        <view class="badge" wx:if="{{orderCounts.shipped > 0}}">{{orderCounts.shipped}}</view>
      </view>
      <view class="status-item" bindtap="goOrderList" data-status="completed">
        <view class="status-icon">✅</view>
        <text class="status-text">已完成</text>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section card">
    <view class="menu-item" bindtap="goAddress">
      <text class="menu-icon">📍</text>
      <text class="menu-text">收货地址</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goCoupon">
      <text class="menu-icon">🎫</text>
      <text class="menu-text">优惠券</text>
      <view class="menu-badge" wx:if="{{couponCount > 0}}">{{couponCount}}张可用</view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goPoints">
      <text class="menu-icon">💰</text>
      <text class="menu-text">积分</text>
      <text class="menu-value">{{points}}分</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goFavorite">
      <text class="menu-icon">❤️</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu-section card">
    <view class="menu-item" bindtap="contactService">
      <text class="menu-icon">💬</text>
      <text class="menu-text">联系客服</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
