/* pages/order-confirm/order-confirm.wxss */
.container { padding-bottom: 120rpx; background-color: #f5f5f5; min-height: 100vh; }

/* 地址选择 */
.address-section { display: flex; align-items: center; padding: 30rpx; position: relative; }
.address-info { flex: 1; }
.address-header { display: flex; align-items: center; margin-bottom: 12rpx; }
.address-name { font-size: 32rpx; font-weight: 600; color: #333; margin-right: 20rpx; }
.address-phone { font-size: 28rpx; color: #666; }
.address-detail { font-size: 26rpx; color: #666; line-height: 1.6; }
.no-address { flex: 1; font-size: 28rpx; color: #999; }
.arrow { font-size: 32rpx; color: #ccc; }

/* 商品列表 */
.goods-section { margin: 20rpx; border-radius: 16rpx; overflow: hidden; }
.goods-item { display: flex; padding: 24rpx; background-color: white; border-bottom: 1rpx solid #f5f5f5; }
.goods-item:last-child { border-bottom: none; }
.goods-image { width: 160rpx; height: 160rpx; border-radius: 12rpx; background-color: #f5f5f5; flex-shrink: 0; }
.goods-info { flex: 1; margin-left: 20rpx; }
.goods-name { font-size: 28rpx; color: #333; display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.goods-spec { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }
.goods-price-row { display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx; }
.goods-price { font-size: 32rpx; color: #E91E63; font-weight: 500; }
.goods-quantity { font-size: 24rpx; color: #999; }

/* 优惠券 */
.coupon-section { display: flex; align-items: center; padding: 30rpx; background-color: white; margin: 20rpx; border-radius: 16rpx; }
.label { font-size: 28rpx; color: #333; flex-shrink: 0; }
.value { flex: 1; text-align: right; font-size: 28rpx; color: #E91E63; margin-right: 16rpx; }

/* 备注 */
.remark-section { display: flex; align-items: center; padding: 30rpx; background-color: white; margin: 20rpx; border-radius: 16rpx; }
.remark-input { flex: 1; margin-left: 20rpx; font-size: 28rpx; }

/* 底部结算 */
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background-color: white; display: flex; align-items: center; justify-content: space-between; padding: 20rpx 30rpx; box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.08); padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); }
.total-section { display: flex; align-items: baseline; }
.total-label { font-size: 28rpx; color: #333; }
.total-price { font-size: 40rpx; color: #E91E63; font-weight: 600; }
.btn-submit { background: linear-gradient(135deg, #E91E63, #F48FB1); color: white; padding: 24rpx 80rpx; border-radius: 44rpx; font-size: 32rpx; font-weight: 500; }
