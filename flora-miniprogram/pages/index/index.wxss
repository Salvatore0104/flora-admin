/* pages/index/index.wxss - Flora花店首页样式 */

.container {
  padding: 0;
  background-color: var(--bg-cream);
  padding-bottom: 20rpx;
}

/* 搜索栏 */
.search-bar {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.95);
  border-radius: 44rpx;
  padding: 16rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 轮播图 */
.banner-section {
  padding: 20rpx 30rpx;
}

.banner-swiper {
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

/* 分类导航 */
.category-nav {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
  background-color: #fff;
  margin: 0 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 20%;
}

.category-icon {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 12rpx;
  border-radius: 50%;
  background: #F5F5F5;
  padding: 16rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 秒杀专区 */
.seckill-section {
  margin: 20rpx 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title-wrap {
  display: flex;
  align-items: center;
}

.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.seckill-timer {
  font-size: 24rpx;
  color: #E91E63;
  background-color: #FCE4EC;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.section-more {
  font-size: 24rpx;
  color: #999;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-left: 16rpx;
}

.seckill-scroll {
  white-space: nowrap;
}

.seckill-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 20rpx;
  text-align: center;
}

.seckill-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
}

.seckill-price {
  display: block;
  font-size: 32rpx;
  color: #E91E63;
  font-weight: 600;
  margin-top: 12rpx;
}

.seckill-original-price {
  display: block;
  font-size: 24rpx;
  color: #999;
  text-decoration: line-through;
}

/* 精选推荐 */
.recommend-section {
  padding: 30rpx;
}

.recommend-section .section-header {
  padding: 0 0 20rpx 0;
}

.goods-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.goods-card {
  width: 335rpx;
  background-color: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}

.goods-card:active {
  transform: scale(0.98);
}

.goods-image {
  width: 100%;
  height: 335rpx;
  background-color: #f5f5f5;
}

.goods-info {
  padding: 16rpx 20rpx 20rpx;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  line-height: 1.4;
  height: 78rpx;
}

.goods-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.goods-price {
  color: #E91E63;
  font-weight: 600;
}

.price-symbol {
  font-size: 24rpx;
}

.price-value {
  font-size: 36rpx;
}

.goods-sales {
  font-size: 22rpx;
  color: #999;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 24rpx;
}
