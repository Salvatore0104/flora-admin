<!--pages/coupon/coupon.wxml - 优惠券页-->
<view class="container">
  <!-- 标签页 -->
  <view class="tabs">
    <view class="tab {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-tab="0">
      <text>未使用</text>
    </view>
    <view class="tab {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-tab="1">
      <text>已使用</text>
    </view>
    <view class="tab {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-tab="2">
      <text>已过期</text>
    </view>
  </view>

  <!-- 优惠券列表 -->
  <view class="coupon-list" wx:if="{{couponList.length > 0}}">
    <view class="coupon-item" wx:for="{{couponList}}" wx:key="id">
      <view class="coupon-left">
        <view class="coupon-amount">
          <text class="currency">¥</text>
          <text class="amount">{{item.amount}}</text>
        </view>
        <text class="coupon-condition">满{{item.minAmount}}可用</text>
      </view>
      <view class="coupon-right">
        <text class="coupon-name">{{item.name}}</text>
        <text class="coupon-validity">有效期至{{item.expireDate}}</text>
        <text class="coupon-desc">{{item.desc}}</text>
      </view>
      <view class="coupon-action">
        <view class="use-btn" wx:if="{{currentTab === 0}}" bindtap="useCoupon" data-id="{{item.id}}">立即使用</view>
        <text class="used-mark" wx:elif="{{currentTab === 1}}">已使用</text>
        <text class="expired-mark" wx:else>已过期</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="text">暂无优惠券</text>
  </view>
</view>
