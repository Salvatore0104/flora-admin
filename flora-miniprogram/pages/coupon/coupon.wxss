/* pages/coupon/coupon.wxss */
.container { padding: 20rpx; background-color: #f5f5f5; min-height: 100vh; }

/* 标签页 */
.tabs { display: flex; background-color: white; border-radius: 12rpx; margin-bottom: 20rpx; padding: 8rpx; }
.tab { flex: 1; text-align: center; padding: 20rpx; font-size: 28rpx; color: #666; border-radius: 8rpx; transition: all 0.3s; }
.tab.active { background-color: #333333; color: white; font-weight: 500; }

/* 优惠券列表 */
.coupon-list { padding-bottom: 20rpx; }

.coupon-item { display: flex; background-color: white; border-radius: 16rpx; margin-bottom: 20rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08); }

.coupon-left { width: 220rpx; background: linear-gradient(135deg, #E91E63, #F48FB1); display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 30rpx 20rpx; position: relative; }
.coupon-left::after { content: ''; position: absolute; right: -12rpx; top: 50%; transform: translateY(-50%); width: 24rpx; height: 24rpx; background-color: #f5f5f5; border-radius: 50%; }

.coupon-amount { color: white; }
.currency { font-size: 28rpx; }
.amount { font-size: 56rpx; font-weight: 700; }

.coupon-condition { font-size: 22rpx; color: rgba(255,255,255,0.9); margin-top: 8rpx; }

.coupon-right { flex: 1; padding: 24rpx; display: flex; flex-direction: column; justify-content: space-between; }
.coupon-name { font-size: 28rpx; color: #333; font-weight: 500; }
.coupon-validity { font-size: 22rpx; color: #999; margin-top: 8rpx; }
.coupon-desc { font-size: 22rpx; color: #666; margin-top: 8rpx; }

.coupon-action { padding: 20rpx; display: flex; align-items: center; }
.use-btn { background: linear-gradient(135deg, #E91E63, #F48FB1); color: white; padding: 12rpx 30rpx; border-radius: 30rpx; font-size: 24rpx; }
.used-mark { font-size: 24rpx; color: #999; }
.expired-mark { font-size: 24rpx; color: #ccc; }

/* 空状态 */
.empty-state { display: flex; justify-content: center; padding: 200rpx 0; }
.empty-state .text { font-size: 28rpx; color: #999; }
