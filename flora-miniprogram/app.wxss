/**app.wxss - Flora花店全局样式**/

/* 全局配色变量 - 鲜花主题色 */
page {
  --primary-color: #e86b7b;
  --primary-light: #ed9199;
  --primary-dark: #d85a68;
  --accent-color: #e86b7b;
  --accent-light: #ed9199;
  --bg-cream: #fdf6f9;
  --bg-white: #FFFFFF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-hint: #999999;
  --divider-color: #f5e0e2;
  --error-color: #FF4D4F;
  --success-color: #67c23a;
  --warning-color: #e6a23c;
  
  font-family: 'PingFang SC', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  background-color: var(--bg-cream);
}

/* 通用样式 */
.container {
  padding: 20rpx;
  background-color: var(--bg-cream);
  min-height: 100vh;
}

/* 卡片样式 */
.card {
  background-color: var(--bg-white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: white;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

.btn-accent {
  background: linear-gradient(135deg, var(--accent-color), var(--accent-light));
  color: white;
  border: none;
  border-radius: 44rpx;
  padding: 20rpx 40rpx;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
}

/* 价格样式 */
.price {
  color: var(--accent-color);
  font-size: 36rpx;
  font-weight: 600;
}

.price-symbol {
  font-size: 24rpx;
  margin-right: 4rpx;
}

/* 标题样式 */
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 商品卡片 */
.goods-card {
  background: var(--bg-white);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.goods-card image {
  width: 100%;
  height: 320rpx;
}

.goods-card .info {
  padding: 16rpx 20rpx;
}

.goods-card .name {
  font-size: 28rpx;
  color: var(--text-primary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.goods-card .price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-state .text {
  color: var(--text-hint);
  font-size: 28rpx;
}

/* 加载更多 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-hint);
  font-size: 24rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--divider-color);
  margin: 20rpx 0;
}

/* 徽章 */
.badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  background-color: var(--accent-color);
  color: white;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}
